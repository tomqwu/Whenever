# Copy to .env and fill in your values. The app auto-loads .env via python-dotenv — no need to export manually.

# --- Ollama LLM ---
# Local Ollama (default — no API key needed):
OLLAMA_HOST=http://localhost:11434
# Model tiers (Ollama, 2026): small/fast (8GB) qwen3.5:4b; default/balanced qwen3:8b;
# prosumer (16-24GB) qwen3:30b; cloud (OLLAMA_HOST=https://ollama.com) gpt-oss:120b or qwen3:30b
OLLAMA_MODEL=qwen3:8b

# Ollama Cloud (https://ollama.com): set all three vars below.
# Get your API key at: https://ollama.com/settings/keys
# Example cloud models: gpt-oss:120b, qwen3.5
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=<your key from ollama.com/settings/keys>
# OLLAMA_MODEL=gpt-oss:120b

# When OLLAMA_API_KEY is unset the app behaves exactly as before (local Ollama, no auth).
OLLAMA_API_KEY=

# --- Web server ---
# Dev-server port. Defaults to 5001 to avoid the macOS AirPlay Receiver (which holds 5000).
PORT=5001

# --- Output currency ---
CURRENCY=cad

# --- Demo / sample mode (#44) -------------------------------------------------
# OPT-IN, clearly-labeled SAMPLE-fare mode for exploring the app WITHOUT any
# provider key. Default OFF. When set to 1/true/yes, EVERY fare is a deterministic,
# obviously-fake sample (carrier "DemoAir") tagged source="demo", NO real provider
# is ever called, the UI shows a prominent persistent "DEMO DATA — NOT real prices"
# banner, and the AI summary is prefixed "(DEMO ...)".
#
# This is the SOLE sanctioned exception to the real-data-only guardrail, and ONLY
# because it is explicit and unmistakably labeled. Demo data is NEVER:
#   - a silent fallback when providers fail/aren't configured (that path returns
#     "no data" — demo only ever appears when DEMO_MODE is explicitly ON), nor
#   - written to the real fare cache (FARE_CACHE_PATH).
# Leave this OFF (blank) for any real pricing.
DEMO_MODE=

# --- Flight pricing API (configure at least one; pricing is real-data only) ---
# RapidAPI flights-sky (Skyscanner data — PREFERRED provider; richest data:
# duration, airlines, layovers). Sign up at https://rapidapi.com and subscribe to
# the "flights-sky" API; place IDs are plain IATA codes (no resolution step).
RAPIDAPI_KEY=
RAPIDAPI_HOST=flights-sky.p.rapidapi.com
# The flights-sky search session completes ASYNCHRONOUSLY: after search-roundtrip we
# poll search-incomplete until context.status == "complete". This budget is longer-
# but-BOUNDED so most routes (incl. long-haul) finish instead of falling back to
# serpapi, while a hung session still degrades to no-data within bounded time
# (~ attempts*interval + one poll timeout). Defaults: ~12 x 1.5s ~= 18s of waiting.
# The INITIAL search-roundtrip call is itself async and slow to return its session:
# ~25-30s for real long-haul (measured 27.3s live for YYZ->PEK), sometimes more — but
# the response IS progressing the whole time. We pass requests a (connect, read)
# timeout:
#   * SKYSCANNER_CONNECT_TIMEOUT (default 10): bounds CONNECTION setup so a DEAD host
#     fails fast instead of hanging.
#   * SKYSCANNER_SEARCH_TIMEOUT (default 90): the READ / INACTIVITY timeout. requests
#     fires it ONLY after this many seconds of NO bytes arriving — it is NOT a total
#     wall-clock cap. As long as flights-sky keeps the response progressing the app
#     keeps waiting; it gives up only after prolonged SILENCE. 90 is generous so a
#     slow-but-alive search completes instead of being killed mid-flight (the old
#     tight cap dropped real long-haul results every time).
SKYSCANNER_CONNECT_TIMEOUT=10
SKYSCANNER_SEARCH_TIMEOUT=90
# Poll budget for /web/flights/search-incomplete (the async session often needs many
# polls to reach "complete" on slow long-haul routes). Generous but bounded.
SKYSCANNER_POLL_ATTEMPTS=24
SKYSCANNER_POLL_INTERVAL=1.5
SKYSCANNER_POLL_TIMEOUT=20
# A single slow/timed-out poll must NOT abort the search (the session is likely still
# working). We only bail after this many CONSECUTIVE silent polls; a poll that responds
# resets the counter. See docs/flights-sky-api.md for the full provider reference.
SKYSCANNER_POLL_MAX_STALLS=3
# Verbose provider tracing: set SKYSCANNER_VERBOSE=1 to log every flights-sky call
# (search + each poll) with HTTP status, session status and elapsed time, so you can
# SEE why a search returns no data (e.g. polls timing out / throttled). Off by default.
SKYSCANNER_VERBOSE=0

# SerpApi Google Flights (live Google Flights data, best long-haul coverage):
# Free trial key at https://serpapi.com
SERPAPI_KEY=

# Travelpayouts / Aviasales (recommended, easiest): https://www.travelpayouts.com/
TRAVELPAYOUTS_TOKEN=

# Amadeus Self-Service (alternative): https://developers.amadeus.com/
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Kiwi / Tequila (second cross-check provider, free Self-Service tier): https://tequila.kiwi.com/
KIWI_API_KEY=

# --- Provider retry / backoff (optional) ---
# Bounded exponential-backoff retry for TRANSIENT provider failures on the one-shot
# provider calls (amadeus token + search, travelpayouts, kiwi, serpapi). A blip
# degrades gracefully / recovers instead of immediately dropping the cell.
#
# WHAT IS RETRIED: connection errors (fast TCP refusal / DNS failure) and HTTP 5xx /
#   429 responses. These fail or return quickly, so backoff-and-retry is cheap.
# WHAT IS NOT RETRIED: request Timeouts. A full Timeout has already consumed the
#   per-attempt budget (e.g. 20-30s); retrying would stack stalls and can block a
#   cell for 60-90s with PROVIDER_RETRIES=2. Timeouts are terminal — the helper
#   returns None immediately so the provider falls through to the next one.
#
# PROVIDER_RETRIES   = max extra attempts (retries+1 total). 0 disables retrying.
# PROVIDER_BACKOFF   = base seconds; sleep = BACKOFF * 2**attempt, each capped at
#                      PROVIDER_BACKOFF_MAX. Default 2 x 0.5s ~= 1.5s worst-case wait.
# PROVIDER_BACKOFF_MAX = per-sleep cap (also clamps a 429 Retry-After header) so a
#                      single cell can never stall for minutes — strictly bounded.
# (The Skyscanner poll path keeps its own bounded 502 retry and is NOT double-retried.)
PROVIDER_RETRIES=2
PROVIDER_BACKOFF=0.5
PROVIDER_BACKOFF_MAX=4

# --- Fare cache (optional) ---
# Seconds to cache real priced results in memory. Set to 0 to disable.
FARE_CACHE_TTL=3600
# JSON file the fare cache is persisted to so real fares survive a restart,
# reducing provider calls/quota. Each entry records its FETCH time and is
# revalidated against the CURRENT FARE_CACHE_TTL on load, so lowering the TTL takes
# effect immediately (old long-TTL fares are dropped, never served stale). Empty =
# memory-only (no disk I/O). FARE_CACHE_TTL <= 0 disables caching AND persistence.
# Only real priced results are persisted; no-data sentinels are never written.
FARE_CACHE_PATH=whenever_fare_cache.json

# --- Concurrent grid fetch ---
# Max parallel threads used to fetch the departure×return fare grid.
# Each cell is one provider call; large grids × many cities = many API calls (quota/cost).
# Keep date spans modest (default UI: 2×2) to stay within provider quotas.
SEARCH_CONCURRENCY=8

# --- Search quota guard ---
# Hard cap on search grid size (cities × dep_dates × ret_dates). Each cell = one provider call.
# Requests exceeding the cap are rejected with HTTP 400 before any fare API calls are made.
# Set to 0 (or any value <= 0) to disable the cap entirely.
# The frontend also shows a soft confirm() dialog above 40 cells (CONFIRM_CELLS in index.html).
MAX_SEARCH_CELLS=200

# Generous per-direction day cap. dep_span/ret_span (and date_range's count) are
# clamped to this ceiling BEFORE the date arrays are expanded, so a malformed huge
# span (e.g. dep_span=10000000) can't allocate millions of dates and tie up the
# worker before the cell cap's 400 fires. The form max is small; this is a safety
# ceiling, not the typical value.
MAX_DATE_SPAN=60

# --- Anti-abuse rate limiting (#60) ---
# Set RATE_LIMIT_ENABLED=false (or 0/no) to disable entirely (e.g. in tests or behind a reverse proxy that handles rate limiting).
# RATE_LIMIT_WINDOW controls the sliding-window size in seconds.
# SEARCH_RATE_PER_MIN is the max requests per window for the "search" bucket
#   (/api/search, /api/search/stream, /api/export/csv, /api/export/pdf).
# API_RATE_PER_MIN is the max requests per window for the "api" bucket
#   (/api/top-cities, /api/suggest, /api/resolve, /api/watch POST/GET, /api/watch/<id> DELETE).
# / and /api/health are always exempt.
# On limit exceeded: HTTP 429 with JSON {"error":"rate limit exceeded, slow down"} and a Retry-After header.
# TRUST_PROXY: set true (1/true/yes) ONLY when behind a trusted reverse proxy that sets X-Forwarded-For.
#   Default false: the X-Forwarded-For header is ignored and the rate-limit bucket keys on the real
#   socket peer (REMOTE_ADDR), so a client cannot rotate/spoof XFF to bypass 429s or burn another user's quota.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
SEARCH_RATE_PER_MIN=10
API_RATE_PER_MIN=60
TRUST_PROXY=false

# --- Price-watch scheduler (optional) ---
# Path to the SQLite DB file used by watch.py / scheduler.py.
# Defaults to whenever_watches.db in the working directory.
WATCH_DB=

# Webhook URL to POST a JSON body on each price drop. Leave blank to disable.
WATCH_WEBHOOK_URL=
